{
  "expo": {
    "name": "ZeniPay",
    "slug": "zenipay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.zenipay.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely unlock ZeniPay.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zenipay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow ZeniPay to use Face ID to unlock the app."
        }
      ]
    ],
    "extra": {
      "apiBase": "https://zenipay.ca"
    }
  }
}
